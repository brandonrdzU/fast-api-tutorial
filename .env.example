# FastAPI OCR Application Configuration

# Environment
ENVIRONMENT=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Python
PYTHONUNBUFFERED=1

# Azure Configuration (uncomment and fill for Azure deployment)
# AZURE_REGISTRY_NAME=your-registry-name
# AZURE_REGISTRY_URL=your-registry-url.azurecr.io
# AZURE_RESOURCE_GROUP=your-resource-group
# AZURE_APP_SERVICE_NAME=your-app-service-name
# AZURE_LOCATION=eastus
